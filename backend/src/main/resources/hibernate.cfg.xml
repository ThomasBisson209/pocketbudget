<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>
        <property name="hibernate.connection.driver_class">org.h2.Driver</property>
        <property name="hibernate.connection.url">jdbc:h2:mem:pocketbudget;DB_CLOSE_DELAY=-1</property>
        <property name="hibernate.connection.username">sa</property>
        <property name="hibernate.connection.password"></property>
        <property name="hibernate.dialect">org.hibernate.dialect.H2Dialect</property>
        <property name="hibernate.hbm2ddl.auto">create</property>
        <property name="show_sql">false</property>
        <property name="hibernate.connection.pool_size">5</property>

        <mapping class="pocketbudget.domain.account.Account"/>
        <mapping class="pocketbudget.domain.budget.Budget"/>
        <mapping class="pocketbudget.domain.user.User"/>
        <mapping class="pocketbudget.domain.transaction.Transaction"/>
    </session-factory>
</hibernate-configuration>
